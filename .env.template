# RAG System Environment Variables - Ollama専用版

# ===========================================
# RAG System 動作モード設定
# ===========================================
USE_OLLAMA=true          # Ollama使用
LIGHTWEIGHT_MODE=false   # フル機能版（軽量版: true）

# ===========================================
# Ollama設定 (ローカルLLM使用)
# ===========================================
OLLAMA_URL=http://127.0.0.1:11434

# LLMモデル 
LLM_MODEL=gpt-oss:20b

# 埋め込みモデル (ローカル)
EMBEDDING_MODEL=nomic-embed-text

# ===========================================
# データベース設定
# ===========================================
POSTGRES_DB=ragdb
POSTGRES_USER=raguser
POSTGRES_PASSWORD=ragpassword

# ===========================================
# サービスURL
# ===========================================
RAG_SERVICE_URL=http://127.0.0.1:8000
DOCUMENT_PROCESSOR_URL=http://127.0.0.1:8001

# ===========================================
# パフォーマンス設定
# ===========================================
# チャンクサイズ (トークン数)
CHUNK_SIZE=1000
CHUNK_OVERLAP=100

# 検索設定
MAX_CHUNKS=5
SIMILARITY_THRESHOLD=0.7

# ===========================================
# 詳細設定
# ===========================================
# ログレベル (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# GPU使用 (NVIDIA GPU環境でのみ有効)
# CUDA_VISIBLE_DEVICES=0
